SECRET_KEY=please-change-me
JWT_SECRET=please-change-me-too
JWT_EXP_HOURS=12

# Database — leave USE_INMEMORY_DB=true for zero-setup local dev
USE_INMEMORY_DB=true
MONGO_URI=mongodb://localhost:27017
MONGO_DB=dna_secure_vault

HOST=0.0.0.0
PORT=5000

# Brute-force protection
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=300

# Rate limits (Flask-Limiter syntax)
RATE_LIMIT_DEFAULT=200 per minute
RATE_LIMIT_AUTH=10 per minute
RATE_LIMIT_ATTACK=20 per minute

CORS_ORIGINS=*
